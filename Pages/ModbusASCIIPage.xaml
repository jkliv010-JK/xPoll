<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="xPoll.Pages.ModbusASCIIPage"
             Title="Modbus ASCII">
  <ScrollView>
    <VerticalStackLayout
        Padding="10"
        Spacing="20">

        <Label Text="Modbus ASCII Configuration" FontSize="24" />

        <Entry x:Name="PortEntry" Placeholder="Enter COM Port or IP" />
        <Entry x:Name="ParametersEntry" Placeholder="Enter ASCII Params" />

        <Button Text="Connect" />
    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
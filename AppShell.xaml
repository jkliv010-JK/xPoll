<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="xPoll.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:xPoll"
    Title="xPoll">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Modbus RTU"
        ContentTemplate="{DataTemplate local:Pages.ModbusRTUPage}"
        Route="ModbusRTUPage" />
    <ShellContent
        Title="Modbus ASCII"
        ContentTemplate="{DataTemplate local:Pages.ModbusASCIIPage}"
        Route="ModbusASCIIPage" />
    <ShellContent
        Title="Modbus TCP"
        ContentTemplate="{DataTemplate local:Pages.ModbusTCPPage}"
        Route="ModbusTCPPage" />
</Shell>
